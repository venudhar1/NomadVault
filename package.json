{
  
  "name": "vaultkey-password-manager",
  
  "version": "1.0.0",
  
  "description": "Zero-knowledge password manager with end-to-end encryption",
  
  "type": "module",
  
  "main": "electron-main.js",
  
  "homepage": "./",
  
  "scripts": {
  
    
  "dev": "vite",
  
    
  "build": "tsc && vite build",
  
    
  "preview": "vite preview",
  
    
  "type-check": "tsc --noEmit",
  
    
  "electron": "electron .",
  
    
  "electron-prod": "npm run build && electron .",
  
    
  "electron-dev": "concurrently \"npm run dev\" \"wait-on http://localhost:5173 && electron .\"",
  
    
  "electron-build": "npm run build && electron-builder"
  
  },
  
  "devDependencies": {
  
    
  "@libsql/client": "^0.5.0",
  
    
  "@types/react": "^18.2.0",
  
    
  "@types/react-dom": "^18.2.0",
  
    
  "@typescript-eslint/eslint-plugin": "^6.0.0",
  
    
  "@typescript-eslint/parser": "^6.0.0",
  
    
  "@vitejs/plugin-react": "^4.2.0",
  
    
  "concurrently": "^9.2.1",
  
    
  "electron": "^42.1.0",
  
    
  "electron-builder": "^26.8.1",
  
    
  "electron-is-dev": "^3.0.1",
  
    
  "eslint": "^8.52.0",
  
    
  "prettier": "^3.0.0",
  
    
  "react": "^18.2.0",
  
    
  "react-dom": "^18.2.0",
  
    
  "typescript": "^5.2.0",
  
    
  "vite": "^5.0.0",
  
    
  "vitest": "^0.34.0",
  
    
  "wait-on": "^9.0.10"
  
  },
  
  "engines": {
  
    
  "node": ">=18.0.0",
  
    
  "npm": ">=9.0.0"
  
  },
  
  "keywords": [
  
    
  "password-manager",
  
    
  "encryption",
  
    
  "zero-knowledge",
  
    
  "aes-256",
  
    
  "security"
  
  ],
  
  "author": "",
  
  "license": "MIT",
  
  "repository": {
  
    
  "type": "git",
  
    
  "url": ""
  
  },
  
  "build": {
  
    
  "appId": "com.vaultkey.app",
  
    
  "productName": "VaultKey",
  
    
  "directories": {
  
    
    
  "output": "release"
  
    
  },
  
    
  "extraMetadata": {
  
    
    
  "dependencies": {}
  
    
  },
  
    
  "npmRebuild": false,
  
    
  "files": [
  
    
    
  "dist/**/*",
  
    
    
  "electron-main.js",
  
    
    
  "preload.cjs",
  
    
    
  "package.json"
  
    
  ],
  
    
  "win": {
  
    
    
  "target": [
  
    
    
    
  "nsis"
  
    
    
  ],
  
    
    
  "signAndEditExecutable": false
  
    
  },
  
    
  "mac": {
  
    
    
  "target": [
  
    
    
    
  "dmg",
  
    
    
    
  "zip"
  
    
    
  ]
  
    
  },
  
    
  "linux": {
  
    
    
  "target": [
  
    
    
    
  "AppImage"
  
    
    
  ]
  
    
  }
  
  }
}
